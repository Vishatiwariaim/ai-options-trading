# ===== Backend =====
APP_NAME=AI Options Trading Platform
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database: leave as sqlite for dev, or set a postgres URL
DATABASE_URL=sqlite:///./trading.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/trading

# Redis (optional; caching falls back to in-memory if unset)
REDIS_URL=

# CORS (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000

# Market data
MARKET_DATA_PROVIDER=yfinance
NSE_OPTION_CHAIN_BASE=https://www.nseindia.com

# Upstox (optional) — REAL option-chain data. Create an app at
# https://account.upstox.com/developer/apps (Redirect URI = https://127.0.0.1),
# then run: python -m scripts.upstox_login  (token expires 3:30 AM IST daily)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://127.0.0.1

# ===== Frontend =====
NEXT_PUBLIC_API_BASE=http://localhost:8000
